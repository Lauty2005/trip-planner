# PostgreSQL
DATABASE_URL=postgresql://usuario:password@localhost:5432/trip_planner

# JWT
JWT_SECRET=cambiar_esto_por_un_secreto_largo_y_random
JWT_EXPIRES_IN=7d

# Servidor
PORT=3000

# Amadeus (self-service) — para /hotels/search y /flights/search
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Google Geocoding API — para convertir lugar/dirección de texto a lat/lng
# (actividades y hoteles cargados a mano). Sin esto, geocoding.ts cae a
# Nominatim (OpenStreetMap, gratis, sin key) como fallback.
# Consola: https://console.cloud.google.com/google/maps-apis/credentials
# Hay que habilitar el "Geocoding API" en el proyecto de Google Cloud.
GOOGLE_MAPS_API_KEY=
