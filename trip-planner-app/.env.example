# URL del backend (Node/Express). En desarrollo local con Expo Go en el
# celular, "localhost" no funciona: usá la IP de tu compu en la red WiFi.
EXPO_PUBLIC_API_URL=http://192.168.0.10:3000/api/v1

# Google Maps API key para Android (react-native-maps la necesita ahí,
# iOS usa Apple Maps nativo y no requiere key).
# Se configura también en app.json > android.config.googleMaps.apiKey
GOOGLE_MAPS_API_KEY=
